# ============================================================
#  SkillSync - Environment Configuration Template
#  Copy this file to .env and fill in the real values
#  cp .env.example .env
# ============================================================

# ======================== DOCKER HUB ========================
DOCKERHUB_USERNAME=aksahoo1097

# ======================== DATABASE ==========================
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ======================== EUREKA ============================
EUREKA_HOST=eureka-server

# ===================== CONFIG SERVER ========================
CONFIG_SERVER_HOST=config-server

# ======================== RABBITMQ ==========================
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=CHANGE_ME_RABBITMQ_PASSWORD

# ======================== REDIS ==============================
REDIS_HOST=redis
REDIS_PORT=6379

# ======================== ZIPKIN ==============================
ZIPKIN_HOST=zipkin

# ======================== EMAIL =============================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=YOUR_GMAIL_APP_PASSWORD

# ======================== CORS ==============================
# IMPORTANT: Add your EC2 public IP here for production!
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost,http://54.80.14.232

# ======================== APP BASE URL ======================
# Used in email links — set to your EC2 public IP or domain
APP_BASE_URL=http://54.80.14.232

# ======================== JPA ===============================
# Use 'update' for first run to create schemas, then switch to 'validate'
JPA_DDL_AUTO=validate

# ======================== JWT ===============================
JWT_SECRET=CHANGE_ME_BASE64_ENCODED_SECRET_KEY_AT_LEAST_256_BITS

# ======================== JVM ===============================
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC -XX:+UseContainerSupport

# ======================== GOOGLE OAUTH ======================
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
